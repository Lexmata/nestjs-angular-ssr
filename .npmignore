# Belt-and-braces ignore file. `package.json` "files" already whitelists
# `dist`, so this mostly exists to defend against someone dropping that
# field in the future — keep it in sync when moving files around.

# Source files (dist is what we publish)
lib/

# Tests
**/*.spec.ts
coverage/
vitest.config.*
vitest.setup.*

# Example application
example/

# GitHub Pages docs site
docs/

# Developer worktrees
.worktrees/

# Config files
tsconfig.json
tsconfig.eslint.json
eslint.config.*
.eslintrc*
.prettierrc*
.prettierignore
commitlint.config.*

# Husky & Git hooks
.husky/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Development & CI
.git/
.github/
.gitignore
*.log

# Package managers
pnpm-lock.yaml
pnpm-workspace.yaml
yarn.lock
package-lock.json

# Misc
*.tgz
.env*
.DS_Store
Thumbs.db
